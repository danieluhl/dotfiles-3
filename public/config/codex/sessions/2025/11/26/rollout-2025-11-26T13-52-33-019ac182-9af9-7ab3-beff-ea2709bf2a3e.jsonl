{"timestamp":"2025-11-26T18:53:36.878Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_ATqygqnrhKDMaCtlqOkeiEUs","output":"Exit code: 0\nWall time: 0 seconds\nOutput:\nimport { Box, Flex, Select, Text } from '@chakra-ui/react';\nimport { AccountDocument, AccountDocumentType, DocumentCategory } from '@domain/accountDocument';\nimport { FileUpload } from '@state/utils';\nimport { UploadIcon } from '@ui/assets/icons/UploadIcon';\nimport { FormControl } from '@ui/components/formControls/FormControl';\nimport { useControl } from '@ui/components/formControls/hooks';\nimport { FileUploader } from '@ui/components/molecules/FileUploader';\nimport { Upload } from '@ui/components/molecules/FileUploader/types';\nimport { Label, Meta } from '@ui/components/typography';\nimport { snakeToCamel } from '@utils/snakeToCamel';\nimport { useEffect, useMemo, useState } from 'react';\nimport { Trans, useTranslation } from 'react-i18next';\nimport { useDocumentationUploader } from './useDocumentationUploader';\n\ntype Props = {\n  currentFile?: AccountDocument;\n  description: string;\n  documentCategory: DocumentCategory;\n  categoryDocuments: AccountDocumentType[];\n  isRequired?: boolean;\n  label: string;\n};\n\nexport const DocumentationUploader = ({\n  currentFile,\n  description,\n  documentCategory,\n  categoryDocuments,\n  isRequired,\n  label,\n}: Props) => {\n  const { t } = useTranslation('organizationApplication', { keyPrefix: 'documentation.uploader' });\n  const { t: tDocumentation } = useTranslation('organizationApplication', {\n    keyPrefix: 'documentation',\n  });\n  const { error } = useControl({ name: documentCategory });\n  const selectId = `${documentCategory}-document-type`;\n  const selectLabelId = `${selectId}-label`;\n  const initialUploads: FileUpload[] = currentFile\n    ? [\n        {\n          file: new File([], currentFile.file.name),\n          id: currentFile.id,\n          progressPercentage: 100,\n          status: 'complete',\n        },\n      ]\n    : [];\n\n  const fallbackDocumentType = categoryDocuments[0] ?? 'irs_w9';\n  const defaultDocumentType = useMemo<AccountDocumentType>(\n    () => currentFile?.documentType ?? fallbackDocumentType,\n    [currentFile?.documentType, fallbackDocumentType]\n  );\n  const shouldShowSelector = categoryDocuments.length > 1;\n  const [selectedDocumentType, setSelectedDocumentType] =\n    useState<AccountDocumentType>(defaultDocumentType);\n\n  useEffect(() => {\n    if (defaultDocumentType) {\n      setSelectedDocumentType(defaultDocumentType);\n    }\n  }, [defaultDocumentType]);\n\n  const documentOptions = useMemo(\n    () =>\n      categoryDocuments.map((documentType) => ({\n        label: tDocumentation(\n          `${snakeToCamel(documentType)}.heading` as Parameters<typeof tDocumentation>[0]\n        ),\n        value: documentType,\n      })),\n    [categoryDocuments, tDocumentation]\n  );\n\n  const { addFile, removeFile, uploads } = useDocumentationUploader({\n    documentCategory,\n    documentType: selectedDocumentType,\n    initialUploads,\n  });\n\n  const onAddFiles = (files: File[]) => {\n    files.forEach((file) => addFile(file));\n  };\n\n  const uploadArr: Upload[] = uploads.map((upload) => ({\n    file: upload.file,\n    progress: upload.progressPercentage,\n    status: upload.status,\n  }));\n\n  return (\n    <FormControl formLabelProps={{ variant: 'bold' }} isRequired={isRequired} label={label}>\n      <Flex direction=\"column\" gap={2}>\n        <Meta>{description}</Meta>\n        {shouldShowSelector && (\n          <Flex direction=\"column\" gap={1}>\n            <Label id={selectLabelId} variant=\"medium\">\n              {t('documentTypeLabel')}\n            </Label>\n            <Select\n              aria-labelledby={selectLabelId}\n              id={selectId}\n              onChange={(event) =>\n                setSelectedDocumentType(event.target.value as AccountDocumentType)\n              }\n              value={selectedDocumentType}\n              variant=\"outline\"\n            >\n              {documentOptions.map(({ label, value }) => (\n                <option key={value} value={value}>\n                  {label}\n                </option>\n              ))}\n            </Select>\n          </Flex>\n        )}\n        <FileUploader\n          acceptedFileTypes={['application/pdf', 'image/jpeg', 'image/png']}\n          hasError={!!error}\n          onAddFiles={onAddFiles}\n          onRemoveFile={removeFile}\n          previewPath={currentFile?.file.url}\n          uploads={uploadArr}\n          useAbsolutePreviewPath\n        >\n          <Flex alignItems=\"center\" direction=\"column\" gap={2} p={3}>\n            <UploadIcon color=\"neutral.600\" height=\"24px\" width=\"24px\" />\n            <Label variant=\"bold\">\n              <Trans\n                components={[<Text as=\"span\" color=\"blue.600\" key=\"label-text\" />]}\n                i18nKey=\"label\"\n                t={t}\n              />\n            </Label>\n            <Box fontSize={13}>{t('description')}</Box>\n          </Flex>\n        </FileUploader>\n      </Flex>\n    </FormControl>\n  );\n};\n"}}
