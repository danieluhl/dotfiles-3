{"timestamp":"2025-11-18T15:35:06.297Z","type":"response_item","payload":{"type":"function_call_output","call_id":"call_2hb7seH19fmqVh3tHjhw231l","output":"{\"output\":\"import { BorderProps, HStack, StackProps, VStack } from '@chakra-ui/react';\\nimport React, { Children, cloneElement, isValidElement } from 'react';\\n\\n/**\\n * RoundedHStack rounds outer elements and eliminates spacing and any border-radius between siblings\\n */\\ninterface IProps extends StackProps {\\n  rounded?: BorderProps['rounded'];\\n}\\n\\nexport const RoundedHStack = ({\\n  borderColor = 'neutral.400',\\n  children,\\n  rounded = 'lg',\\n  ...props\\n}: IProps) => (\\n  <HStack alignItems=\\\"stretch\\\" size=\\\"sm\\\" spacing=\\\"-1px\\\" {...props}>\\n    {Children.toArray(children).map((child, index, arr) =>\\n      isValidElement(child)\\n        ? cloneElement(child, {\\n            borderColor,\\n            rounded: 0,\\n            // First element has border-radius on left\\n            roundedLeft: index === 0 ? rounded : 0,\\n            // Last element has border-radius on right\\n            roundedRight: index === arr.length - 1 ? rounded : 0,\\n          })\\n        : child\\n    )}\\n  </HStack>\\n);\\n\\nexport const RoundedVStack = ({\\n  borderColor = 'neutral.400',\\n  children,\\n  rounded = 'lg',\\n  ...props\\n}: IProps) => (\\n  <VStack alignItems=\\\"stretch\\\" size=\\\"sm\\\" spacing=\\\"-1px\\\" {...props}>\\n    {Children.toArray(children).map((child, index, arr) =>\\n      isValidElement(child)\\n        ? cloneElement(child, {\\n            borderColor,\\n            rounded: 0,\\n            // Last element has border-radius on right\\n            roundedBottom: index === arr.length - 1 ? rounded : 0,\\n            // First element has border-radius on left\\n            roundedTop: index === 0 ? rounded : 0,\\n          })\\n        : child\\n    )}\\n  </VStack>\\n);\\n\",\"metadata\":{\"exit_code\":0,\"duration_seconds\":0.0}}"}}
