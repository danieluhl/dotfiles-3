+async function waitForMockHeaders(
+  getLatestMockHeaders: () => Record<string, string>,
+  timeoutMs = 1_500,
+) {
+  const start = Date.now();
+  while (Date.now() - start < timeoutMs) {
+    const headers = getLatestMockHeaders();
+    if (Object.keys(headers).length > 0) {
+      console.log(
+        "[pw:rmp:headers-ready]",
+        JSON.stringify({ headerKeys: Object.keys(headers) }),
+      );
+      return;
+    }
+    await new Promise((resolve) => setTimeout(resolve, 10));
+  }
+
+  throw new Error(
+    "Timed out waiting for RMP headers to be ready before navigation.",
+  );
+}
