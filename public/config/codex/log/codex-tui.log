+            const isFormComplete = Object.values(values).every(
+              (value) => value.trim().length > 0,
+            );
+
+            return (
+              <Button
+                type="submit"
+                className="w-full"
+                size="lg"
+                disabled={isPending || !isFormComplete}
+              >
+                Submit
+              </Button>
+            );
+          }}
+        </form.Subscribe>
       </form>
