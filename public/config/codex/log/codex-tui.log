-  await page.goto("/lead/demo-org/lead-token");
+type ActionPage = {
+  id: string;
+  headerTitleText: string;
+  description?: string | null;
+  account: {
+    id: string;
+    displayName: string;
+    allowCustomCss: boolean;
+    slug: string;
+  };
+};
 
-  await expect(
-    page.getByRole("heading", { name: "Join the Movement" }),
-  ).toBeVisible();
-});
+const buildActionPage = (overrides: Partial<ActionPage> = {}): ActionPage => ({
+  id: "ap_123",
+  headerTitleText: "Join the Movement",
+  description: descriptionText,
+  account: {
+    id: "acct_123",
+    displayName: "Demo Org",
+    allowCustomCss: false,
+    slug: "demo-org",
+  },
+  ...overrides,
+});
+
+const test = base.extend<{ network: NetworkFixture }>({
+  network: createNetworkFixture(),
+});
+
+test("shows the description when provided", async ({ page, network }) => {
+  network.use(
+    http.get(`${apiBase}/action_pages/:actionPageSlug`, () => {
+      return HttpResponse.json(buildActionPage());
+    }),
+  );
+
+  await page.goto("/lead/demo-org/lead-token");
+
+  await expect(
+    page.getByRole("heading", { name: "Join the Movement" }),
+  ).toBeVisible();
+  await expect(page.getByText(descriptionText)).toBeVisible();
+});
+
+test("does not render the description when missing", async ({ page, network }) => {
+  network.use(
+    http.get(`${apiBase}/action_pages/:actionPageSlug`, () => {
+      return HttpResponse.json(buildActionPage({ description: null }));
+    }),
+  );
+
+  await page.goto("/lead/demo-org/lead-token");
+
+  await expect(
+    page.getByRole("heading", { name: "Join the Movement" }),
+  ).toBeVisible();
+  await expect(page.getByText(descriptionText)).toHaveCount(0);
+});
