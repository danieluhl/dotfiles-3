+test("enables submit only after required fields are filled and submits successfully", async ({
+  page,
+  mockServerRequest,
+}) => {
+  await mockPublicActionPage(mockServerRequest);
+
+  let submitRequestCount = 0;
+  await page.route(leadSubmissionUrlPattern, async (route, request) => {
+    if (request.method() !== "PUT") {
+      await route.fallback();
+      return;
+    }
+
+    submitRequestCount += 1;
+    await route.fulfill({
+      status: 200,
+      contentType: "application/json",
+      body: JSON.stringify({
+        id: "lead_123",
+        actionPage: {
+          id: "ap_123",
+          name: "Join the Movement",
+          pageType: "lead",
+        },
+      }),
+    });
+  });
+
+  await page.goto("/lead/demo-org/lead-token");
+
+  const submitButton = page.getByRole("button", { name: "Submit" });
+  await expect(submitButton).toBeDisabled();
+
+  await page.getByLabel("Email").fill("test@example.com");
+  await page.getByLabel("Phone").fill("5555555555");
+  await page.getByLabel("First name").fill("Ada");
+  await page.getByLabel("Last name").fill("Lovelace");
+  await page.getByLabel("Address").fill("123 Main St");
+  await page.getByLabel("City").fill("Austin");
+  await page.getByLabel("State / Province").fill("TX");
+  await page.getByLabel("Postal code").fill("78701");
+  await page.getByLabel("Country").fill("USA");
+
+  await expect(submitButton).toBeEnabled();
+  await submitButton.click();
+
+  await expect.poll(() => submitRequestCount).toBe(1);
+});
+
 test("shows required validation for all required fields on empty submit", async ({
   page,
   mockServerRequest,
 }) => {
